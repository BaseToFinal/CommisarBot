# Discord
DISCORD_TOKEN=

# Railway injects DATABASE_URL automatically when you attach a Postgres plugin.
# Set it manually here only for local development against a local/remote DB.
DATABASE_URL=postgresql://user:password@localhost:5432/vvs_bot

# Optional: set for instant guild-scoped slash command sync during development.
# Leave blank for a global sync (takes up to ~1 hour to propagate).
GUILD_ID=

# Channels
ADMIN_APPROVAL_CHANNEL_ID=
FALLEN_HEROES_CHANNEL_ID=
COMMISSAR_LOG_CHANNEL_ID=
AVATAR_STORAGE_CHANNEL_ID=
PILOT_PHOTO_POOL_CHANNEL_ID=

# Channel where DCSServerBot posts its live status embed (optional —
# only works if your bot has access to that channel; see README)
DCS_STATUS_CHANNEL_ID=

# Daily Orders: where it posts, and what hour (UTC, 0-23) it auto-posts
DAILY_ORDERS_CHANNEL_ID=
DAILY_ORDERS_POST_HOUR_UTC=12

# Real-world airport for reference weather in Daily Orders (ICAO code).
# Defaults to Kabul (OAKB) if unset.
METAR_ICAO_CODE=OAKB

# Roles
COMMISSAR_ROLE_ID=
ADMIN_ROLE_ID=
ACTIVE_FLYER_ROLE_ID=

# Per-airframe squadron roles
SQUADRON_ROLE_MIG21=
SQUADRON_ROLE_MIG29=
SQUADRON_ROLE_SU17=
SQUADRON_ROLE_SU25=
SQUADRON_ROLE_MI8=
SQUADRON_ROLE_MI24=

# OpenAI API key for real avatar generation (DALL-E 3). Leave blank to use
# a placeholder image instead — the bot works fine either way.
IMAGE_GEN_API_KEY=
